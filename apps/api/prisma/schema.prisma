generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  LOCKED
  DISABLED
}

enum LoginResult {
  SUCCESS
  FAILED
  LOCKED
  MFA_REQUIRED
}

model Company {
  id                      String       @id @default(cuid())
  singletonKey            String       @unique @default("single-company")
  name                    String
  logoUrl                 String?
  registrationNumber      String?
  taxRegistrationNumber   String?
  address                 String?
  phone                   String?
  email                   String?
  website                 String?
  baseCurrency            String       @default("SGD")
  financialYearStartMonth Int          @default(1)
  dateFormat              String       @default("dd/MM/yyyy")
  timezone                String       @default("Asia/Singapore")
  defaultTaxCode          String?
  invoiceFooter           String?
  termsAndConditions      String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  branches                Branch[]
  departments             Department[]
  warehouses              Warehouse[]
  costCenters             CostCenter[]
  users                   User[]
  auditLogs               AuditLog[]
  customers               Customer[]
  suppliers               Supplier[]
  items                   Item[]
  itemCategories          ItemCategory[]
  customerCategories      CustomerCategory[]
  supplierCategories      SupplierCategory[]
  unitsOfMeasure          UnitOfMeasure[]
  taxCodes                TaxCode[]
  currencies              Currency[]
  paymentTerms            PaymentTerm[]
  attachments             Attachment[]
  importJobs              ImportJob[]
  emailDeliveryLogs       EmailDeliveryLog[]
  reportSchedules         ReportSchedule[]
  stockBalances           StockBalance[]
  stockLedgerEntries      StockLedgerEntry[]
  stockTransfers          StockTransfer[]
  stockCounts             StockCount[]
  stockAdjustments        StockAdjustment[]
  accounts                Account[]
  financialPeriods        FinancialPeriod[]
  journalEntries          JournalEntry[]
  journalLines            JournalLine[]
  bankReconciliations     BankReconciliation[]
  recurringJournals       RecurringJournal[]
  budgets                 Budget[]
  openingBalanceBatches   OpeningBalanceBatch[]
  yearEndCloses           YearEndClose[]
  accountingMappings      AccountingMapping[]
  supplierPayments        SupplierPayment[]
  leads                   Lead[]
  opportunities           Opportunity[]
  quotations              Quotation[]
  salesOrders             SalesOrder[]
  deliveries              Delivery[]
  activities              Activity[]
  customerEnquiries       CustomerEnquiry[]
  salesInvoices           SalesInvoice[]
  receipts                Receipt[]
  creditNotes             CreditNote[]
  salesReturns            SalesReturn[]
  purchaseRequests        PurchaseRequest[]
  requestForQuotations    RequestForQuotation[]
  supplierQuotations      SupplierQuotation[]
  purchaseOrders          PurchaseOrder[]
  goodsReceipts           GoodsReceipt[]
  supplierInvoices        SupplierInvoice[]
  purchaseReturns         PurchaseReturn[]
  employees               Employee[]
  leaveTypes              LeaveType[]
  leaveRequests           LeaveRequest[]
  attendanceRecords       AttendanceRecord[]
  expenseClaims           ExpenseClaim[]
  approvalRequests        ApprovalRequest[]
  holidays                Holiday[]
  employeeChecklists      EmployeeChecklist[]
}

model Branch {
  id        String       @id @default(cuid())
  companyId String
  code      String
  name      String
  address   String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  departments Department[]
  warehouses  Warehouse[]
  employees   Employee[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Department {
  id        String   @id @default(cuid())
  companyId String
  branchId  String?
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employees Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
}

model Warehouse {
  id        String   @id @default(cuid())
  companyId String
  branchId  String?
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  bins               WarehouseBin[]
  items              Item[]
  stockBalances      StockBalance[]
  stockLedgerEntries StockLedgerEntry[]
  stockTransfersFrom StockTransfer[] @relation("StockTransferFromWarehouse")
  stockTransfersTo   StockTransfer[] @relation("StockTransferToWarehouse")
  stockCounts        StockCount[]
  stockAdjustments   StockAdjustment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
}

model WarehouseBin {
  id          String    @id @default(cuid())
  warehouseId String
  code        String
  name        String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model CostCenter {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, code])
  @@index([companyId])
}

model User {
  id                    String         @id @default(cuid())
  companyId             String
  email                 String         @unique
  username              String         @unique
  displayName           String
  passwordHash          String
  status                UserStatus     @default(INVITED)
  emailVerifiedAt       DateTime?
  invitedAt             DateTime?
  activatedAt           DateTime?
  deactivatedAt         DateTime?
  failedLoginCount      Int            @default(0)
  lockedUntil           DateTime?
  mfaEnabled            Boolean        @default(false)
  mfaSecretEncrypted    String?
  recoveryCodesHash     Json?
  lastLoginAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  company               Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  roles                 UserRole[]
  loginHistory          LoginHistory[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  attachments           Attachment[]
  importJobs            ImportJob[]
  emailDeliveryRequests EmailDeliveryLog[] @relation("EmailDeliveryRequester")
  reportSchedules       ReportSchedule[] @relation("ReportScheduleCreator")
  assignedActivities    Activity[]       @relation("ActivityAssignee")
  completedActivities   Activity[]       @relation("ActivityCompleter")
  purchaseRequests      PurchaseRequest[]
  stockLedgerEntries    StockLedgerEntry[]
  stockTransfers        StockTransfer[]
  stockCounts           StockCount[]
  stockAdjustments      StockAdjustment[]
  journalEntries        JournalEntry[]
  supplierPayments      SupplierPayment[]
  bankReconciliations   BankReconciliation[]
  recurringJournals     RecurringJournal[]
  budgets               Budget[]
  openingBalanceBatches OpeningBalanceBatch[]
  yearEndCloses         YearEndClose[]
  employeeProfile       Employee?
  submittedApprovals    ApprovalRequest[]
  approvalSteps         ApprovalStep[]
  approvalActions       ApprovalAction[]
  assignedLeads         Lead[]
  assignedOpportunities Opportunity[]

  @@index([companyId])
  @@index([status])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  module      String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model LoginHistory {
  id        String      @id @default(cuid())
  userId    String?
  identifier String
  result    LoginResult
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  companyId     String?
  userId        String?
  action        String
  module        String
  recordType    String?
  recordId      String?
  ipAddress     String?
  userAgent     String?
  beforeValue   Json?
  afterValue    Json?
  reason        String?
  correlationId String?
  createdAt     DateTime @default(now())
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([module, createdAt])
}

model ApprovalRule {
  id           String   @id @default(cuid())
  name         String
  documentType String
  minAmount    Decimal? @db.Decimal(18, 4)
  maxAmount    Decimal? @db.Decimal(18, 4)
  branchId     String?
  departmentId String?
  approverRole String
  sequence     Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([documentType, isActive])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model Employee {
  id                    String             @id @default(cuid())
  companyId             String
  employeeCode          String
  userId                String?            @unique
  firstName             String
  lastName              String
  displayName           String
  email                 String?
  phone                 String?
  designation           String?
  departmentId          String?
  branchId              String?
  managerId             String?
  employmentDate        DateTime
  employmentType        String             @default("FULL_TIME")
  status                String             @default("ACTIVE")
  emergencyContactName  String?
  emergencyContactPhone String?
  skills                String?
  certifications        String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  company               Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user                  User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  department            Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  branch                Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  manager               Employee?          @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports         Employee[]         @relation("EmployeeManager")
  leaveRequests         LeaveRequest[]
  attendanceRecords     AttendanceRecord[]
  expenseClaims         ExpenseClaim[]
  checklists            EmployeeChecklist[]

  @@unique([companyId, employeeCode])
  @@index([companyId, status])
  @@index([departmentId])
  @@index([branchId])
  @@index([managerId])
}

model LeaveType {
  id          String         @id @default(cuid())
  companyId   String
  code        String
  name        String
  daysPerYear Decimal        @default(0) @db.Decimal(9, 4)
  isPaid      Boolean        @default(true)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  requests    LeaveRequest[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
}

model LeaveRequest {
  id                String           @id @default(cuid())
  companyId         String
  employeeId        String
  leaveTypeId       String
  startDate         DateTime
  endDate           DateTime
  days              Decimal          @db.Decimal(9, 4)
  status            String           @default("DRAFT")
  reason            String?
  approvalRequestId String?          @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee          Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType         LeaveType        @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  approvalRequest   ApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([employeeId])
  @@index([leaveTypeId])
}

model AttendanceRecord {
  id             String   @id @default(cuid())
  companyId      String
  employeeId     String
  attendanceDate DateTime
  shiftName      String?
  clockIn        DateTime?
  clockOut       DateTime?
  status         String   @default("PRESENT")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([companyId, employeeId, attendanceDate])
  @@index([companyId, attendanceDate])
  @@index([employeeId])
}

model ExpenseClaim {
  id                String           @id @default(cuid())
  companyId         String
  employeeId        String
  claimNo           String
  expenseDate       DateTime
  category          String
  amount            Decimal          @db.Decimal(18, 4)
  status            String           @default("DRAFT")
  description       String?
  approvalRequestId String?          @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee          Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  approvalRequest   ApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)

  @@unique([companyId, claimNo])
  @@index([companyId, status])
  @@index([employeeId])
}

model Holiday {
  id          String   @id @default(cuid())
  companyId   String
  holidayDate DateTime
  name        String
  region      String?
  isPaid      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, holidayDate, name])
  @@index([companyId, holidayDate])
}

model EmployeeChecklist {
  id          String                  @id @default(cuid())
  companyId   String
  employeeId  String
  checklistNo String
  type        String                  @default("ONBOARDING")
  status      String                  @default("OPEN")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee    Employee                @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  lines       EmployeeChecklistLine[]

  @@unique([companyId, checklistNo])
  @@index([companyId, status])
  @@index([employeeId])
}

model EmployeeChecklistLine {
  id          String            @id @default(cuid())
  checklistId String
  task        String
  ownerRole   String?
  dueDate     DateTime?
  status      String            @default("OPEN")
  completedAt DateTime?
  notes       String?
  checklist   EmployeeChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, status])
}

model ApprovalRequest {
  id           String           @id @default(cuid())
  companyId    String
  documentType String
  documentId   String
  documentNo   String?
  amount       Decimal?         @db.Decimal(18, 4)
  status       String           @default("PENDING")
  currentStep  Int              @default(1)
  submittedById String?
  submittedAt  DateTime         @default(now())
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  submittedBy  User?            @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  leaveRequest LeaveRequest?
  expenseClaim ExpenseClaim?
  steps        ApprovalStep[]
  actions      ApprovalAction[]

  @@unique([companyId, documentType, documentId])
  @@index([companyId, status])
  @@index([submittedById])
}

model ApprovalStep {
  id                String           @id @default(cuid())
  approvalRequestId String
  sequence          Int
  approverRole      String
  approverUserId    String?
  status            String           @default("PENDING")
  dueAt             DateTime?
  actedAt           DateTime?
  comments          String?
  approvalRequest   ApprovalRequest  @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  approverUser      User?            @relation(fields: [approverUserId], references: [id], onDelete: SetNull)
  actions           ApprovalAction[]

  @@unique([approvalRequestId, sequence])
  @@index([approvalRequestId, status])
  @@index([approverUserId])
}

model ApprovalAction {
  id                String          @id @default(cuid())
  approvalRequestId String
  stepId            String?
  action            String
  actorUserId       String?
  comments          String?
  createdAt         DateTime        @default(now())
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  step              ApprovalStep?   @relation(fields: [stepId], references: [id], onDelete: SetNull)
  actorUser         User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([approvalRequestId])
  @@index([stepId])
  @@index([actorUserId])
}

model CustomerCategory {
  id        String     @id @default(cuid())
  companyId String
  code      String
  name      String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customers Customer[]

  @@unique([companyId, code])
  @@index([companyId])
}

model SupplierCategory {
  id        String     @id @default(cuid())
  companyId String
  code      String
  name      String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  suppliers Supplier[]

  @@unique([companyId, code])
  @@index([companyId])
}

model ItemCategory {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items     Item[]

  @@unique([companyId, code])
  @@index([companyId])
}

model UnitOfMeasure {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items     Item[]

  @@unique([companyId, code])
  @@index([companyId])
}

model TaxCode {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  ratePercent Decimal  @db.Decimal(9, 4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items       Item[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Currency {
  id        String     @id @default(cuid())
  companyId String
  code      String
  name      String
  symbol    String?
  isBase    Boolean    @default(false)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customers Customer[]
  suppliers Supplier[]

  @@unique([companyId, code])
  @@index([companyId])
}

model PaymentTerm {
  id        String     @id @default(cuid())
  companyId String
  code      String
  name      String
  days      Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customers Customer[]
  suppliers Supplier[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Customer {
  id                    String            @id @default(cuid())
  companyId             String
  code                  String
  name                  String
  customerType          String            @default("Business")
  contactPerson         String?
  phone                 String?
  email                 String?
  billingAddress        String?
  shippingAddress       String?
  taxRegistrationNumber String?
  paymentTermId         String?
  creditLimit           Decimal           @default(0) @db.Decimal(18, 4)
  currencyId            String?
  salespersonId         String?
  branchId              String?
  categoryId            String?
  status                String            @default("ACTIVE")
  notes                 String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  paymentTerm           PaymentTerm?      @relation(fields: [paymentTermId], references: [id], onDelete: SetNull)
  currency              Currency?         @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  category              CustomerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  opportunities         Opportunity[]
  quotations            Quotation[]
  salesOrders           SalesOrder[]
  activities            Activity[]
  enquiries             CustomerEnquiry[]
  salesInvoices         SalesInvoice[]
  receipts              Receipt[]
  creditNotes           CreditNote[]
  salesReturns          SalesReturn[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([status])
}

model Supplier {
  id                    String            @id @default(cuid())
  companyId             String
  code                  String
  name                  String
  contactPerson         String?
  phone                 String?
  email                 String?
  address               String?
  taxRegistrationNumber String?
  paymentTermId         String?
  currencyId            String?
  bankDetailsEncrypted  String?
  categoryId            String?
  status                String            @default("ACTIVE")
  notes                 String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  paymentTerm           PaymentTerm?      @relation(fields: [paymentTermId], references: [id], onDelete: SetNull)
  currency              Currency?         @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  category              SupplierCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items                 Item[]
  supplierQuotations    SupplierQuotation[]
  purchaseOrders        PurchaseOrder[]
  supplierInvoices      SupplierInvoice[]
  purchaseReturns       PurchaseReturn[]
  supplierPayments      SupplierPayment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([status])
}

model Item {
  id                   String         @id @default(cuid())
  companyId            String
  code                 String
  barcode              String?
  name                 String
  description          String?
  itemType             String         @default("Stock")
  categoryId           String?
  brand                String?
  unitOfMeasureId      String?
  purchaseUnit         String?
  salesUnit            String?
  unitConversion       Decimal        @default(1) @db.Decimal(18, 6)
  purchasePrice        Decimal        @default(0) @db.Decimal(18, 4)
  sellingPrice         Decimal        @default(0) @db.Decimal(18, 4)
  minimumSellingPrice  Decimal        @default(0) @db.Decimal(18, 4)
  taxCodeId            String?
  reorderLevel         Decimal        @default(0) @db.Decimal(18, 4)
  safetyStock          Decimal        @default(0) @db.Decimal(18, 4)
  preferredSupplierId  String?
  warehouseId          String?
  binLocation          String?
  batchTracking        Boolean        @default(false)
  serialTracking       Boolean        @default(false)
  expiryTracking       Boolean        @default(false)
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  company              Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category             ItemCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unitOfMeasure        UnitOfMeasure? @relation(fields: [unitOfMeasureId], references: [id], onDelete: SetNull)
  taxCode              TaxCode?       @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)
